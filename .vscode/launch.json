{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "(lldb) Launch", // Or (gdb) Launch on Linux/Windows
      "type": "cppdbg",
      "request": "launch",
      // This is the magic line. It asks the CMake extension for the path to your executable.
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "lldb" // Use "gdb" on Linux/Windows
    }
  ]
}
